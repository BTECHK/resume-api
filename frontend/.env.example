# Frontend runtime environment variables
#
# These are passed as env vars to the Docker container (Cloud Run --set-env-vars
# or docker-compose environment). At startup, envsubst renders config.json.template
# into /config.json, which the React app fetches at runtime.
#
# For local dev without Docker, create a public/config.json file manually:
#   { "aiServiceUrl": "http://localhost:8090", "candidateName": "KA", ... }

# URL of the ai-service Cloud Run service. Must include https:// prefix, NO trailing slash.
AI_SERVICE_URL=https://ai-service-PLACEHOLDER-uc.a.run.app

# Candidate identity used in the hero, header, and auto-greeting.
CANDIDATE_NAME=Your Name
CANDIDATE_TITLE=Software Engineer
CANDIDATE_EMAIL=hello@example.com
