# Frontend build-time environment variables
# Copy this file to .env.local (gitignored) before running `npm run build` or `docker build`.
# Values here are INLINED INTO THE BUNDLE AT BUILD TIME — changing them
# requires a rebuild, not just a container restart (RESEARCH.md Pitfall #4).

# URL of the ai-service Cloud Run service. Must include https:// prefix, NO trailing slash.
# For local dev against a local ai-service: http://localhost:8090
#
# !!! REPLACE AT DEPLOY TIME !!!
# Phase 4 ai-service's ALLOWED_ORIGINS env var must ALSO be updated to the
# frontend Cloud Run URL or the browser will block requests with a CORS error.
# See DEFERRED-WORK.md "Phase 6 — Deferred Manual Steps" Task C for the exact swap procedure.
VITE_AI_SERVICE_URL=https://ai-service-PLACEHOLDER-uc.a.run.app

# Candidate identity used in the hero, header, and auto-greeting.
VITE_CANDIDATE_NAME=Your Name
VITE_CANDIDATE_TITLE=Software Engineer
VITE_CANDIDATE_EMAIL=hello@example.com
