# AI Service — Local Development Environment
# Copy to .env and fill in values: cp .env.example .env

# Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# GCP project ID (for Secret Manager in production)
GCP_PROJECT_ID=your-gcp-project-id

# CORS origins (comma-separated, use * for local dev)
ALLOWED_ORIGINS=*

# Chroma telemetry opt-out
ANONYMIZED_TELEMETRY=false
