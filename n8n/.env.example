# n8n Email Bot environment template (Phase 5)
# Copy this file to /opt/n8n/.env on the VM and fill in real values.
# DO NOT commit the populated .env file (it's in .gitignore).

# ──────────────────────────────────────────────────────────
# n8n Basic Auth (for the UI — only reachable via SSH tunnel)
# ──────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ──────────────────────────────────────────────────────────
# ai-service endpoint (Phase 4 Cloud Run URL)
# Set after Phase 4 deployment completes. Placeholder until then.
# NOTE: This is the Cloud Run HTTPS URL — do NOT append a port suffix.
# The ai-service local dev port (from docker-compose) only applies to
# local dev; Cloud Run terminates HTTPS on 443 implicitly, so the URL
# below must remain portless.
# ──────────────────────────────────────────────────────────
AI_SERVICE_URL=https://ai-service-PLACEHOLDER-uc.a.run.app

# ──────────────────────────────────────────────────────────
# Gmail OAuth (populated after running n8n/docs/gmail-oauth-setup.md)
# ──────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=REPLACE_WITH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
BOT_GMAIL_ADDRESS=resume-bot-REPLACE@gmail.com

# ──────────────────────────────────────────────────────────
# Fallback reply signature (D-06, D-12)
# ──────────────────────────────────────────────────────────
CANDIDATE_NAME=REPLACE_WITH_YOUR_NAME
CANDIDATE_GITHUB=https://github.com/REPLACE
CANDIDATE_PORTFOLIO=https://REPLACE.com
CANDIDATE_CONTACT_EMAIL=REPLACE@example.com
